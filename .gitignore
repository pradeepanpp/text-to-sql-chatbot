# Python
__pycache__/
*.py[cod]
*.pyd
.Python
.venv/
venv/
*.egg-info/
dist/
build/

# Environment — NEVER commit these
.env
.envrc

# Database (generated at runtime by setup_database.py)
database/*.db

# CSV data files (large, regeneratable)
data/csv/*
!data/csv/.gitkeep

# Evaluation results (regeneratable)
data/eval/*
!data/eval/.gitkeep

# Audit logs (runtime generated, may contain sensitive queries)
logs/*
!logs/.gitkeep

# Model cache
models/
.cache/

# IDE
.vscode/
.idea/
*.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Setup script (only needed locally, not for users who clone)
setup_project.py